{
  "name": "team-lunch",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run ports:check && concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:server:sqlite": "node ./scripts/dev-server-sqlite.mjs",
    "dev:client": "vite",
    "ports:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-port-blockers.ps1",
    "ports:check:ci": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-port-blockers.ps1 -NonInteractive",
    "build": "tsc -p tsconfig.build.json && vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "continuity:update": "node scripts/update-continuity.js",
    "semgrep": "semgrep scan --config auto --error .",
    "pretest": "node ./scripts/prisma-generate-safe.mjs",
    "test": "vitest run",
    "pretest:server": "node ./scripts/prisma-generate-safe.mjs",
    "test:server": "vitest run --project server",
    "test:server:sqlite": "node ./scripts/test-server-sqlite.mjs",
    "test:client": "vitest run --project client",
    "test:e2e": "playwright test",
    "duplication": "jscpd src/ --config .jscpd.json",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "auth:seed": "tsx scripts/auth-seed.ts",
    "prisma:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma",
    "prisma:push:sqlite": "prisma db push --schema prisma/schema.sqlite.prisma",
    "validate": "powershell -NoProfile -File ./validate.ps1 all"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "@prisma/client": "^6.4.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.1",
    "jose": "^6.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9.21.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "jscpd": "^4.0.8",
    "jsdom": "^26.0.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.3",
    "prettier": "^3.5.2",
    "prisma": "^6.4.1",
    "sharp-cli": "^5.2.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.7"
  },
  "overrides": {
    "effect": "3.21.0"
  }
}
