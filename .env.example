# Team Lunch example configuration
#
# Copy this file to `.env` and adjust values for your environment.
# Only a few variables are required for a basic local setup:
# - DATABASE_URL
# - AUTH_SESSION_SECRET (required for local auth / auth cookies)
#
# Local Docker defaults:
# - PostgreSQL host port: 5433
# - App backend port: 3000
# - Vite dev frontend port: 5173

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Primary database provider. Use `postgresql` for the normal app setup or
# `sqlite` for lightweight local backend/testing flows.
DB_PROVIDER="postgresql"

# PostgreSQL connection string for local Docker Compose.
DATABASE_URL="postgresql://teamlunch:teamlunch@localhost:5433/teamlunch?schema=public"

# Separate schema used by server tests so app data in `public` is not touched.
TEST_DATABASE_SCHEMA="team_lunch_test"

# Host port exposed by the local PostgreSQL Docker container.
DB_PORT="5433"

# -----------------------------------------------------------------------------
# App server / frontend
# -----------------------------------------------------------------------------

# Backend HTTP port. Used by the Fastify server in dev and production.
PORT="3000"

# Frontend dev-server port. Mainly used for local development when Vite and the
# backend run as separate processes.
VITE_PORT="5173"

# Optional app path prefix for backend routing, e.g. `/team-lunch`.
# Leave empty when serving from the site root:
# - `http://localhost:3000/`
# - `https://example.com/`
# Set both BASE_PATH and VITE_BASE_PATH when serving from a subpath:
# - `http://localhost:3000/team-lunch/`
# - `https://example.com/team-lunch/`
BASE_PATH=""

# Frontend build-time counterpart of BASE_PATH.
# Vite uses this for generated asset URLs and SPA routing. This is not just for
# local dev; it affects the frontend build output.
# Leave empty for root deployments.
# Set it to the same value as BASE_PATH for subpath deployments, for example:
# - BASE_PATH="/team-lunch"
# - VITE_BASE_PATH="/team-lunch"
VITE_BASE_PATH=""

# Public app URL used for redirects and absolute links in production.
# Examples:
# - root deployment: `http://localhost:3000`
# - subpath deployment: `https://example.com/team-lunch`
APP_PUBLIC_URL="http://localhost:3000"

# Server log level (`trace`, `debug`, `info`, `warn`, `error`).
LOG_LEVEL="info"

# Set to `true` to disable the background DB connectivity monitor.
DISABLE_DB_CONNECTIVITY_MONITOR="false"

# Optional global fallback duration used when auto-starting or transitioning
# food selection.
# If unset or invalid, the app falls back to `30`.
# In normal multi-office setups, office-specific settings are typically used
# instead, and new offices also default to `30`.
DEFAULT_FOOD_SELECTION_DURATION_MINUTES=""

# -----------------------------------------------------------------------------
# Local auth / approval flow
# -----------------------------------------------------------------------------

# Required for signed auth cookies. Use a long random secret in real deployments.
# Examples for generating one:
# - Node.js: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# - OpenSSL: `openssl rand -hex 32`
AUTH_SESSION_SECRET="replace-with-a-long-random-secret-of-at-least-32-chars"

# Bootstrap admin email. When set, approval-gated access is enabled.
AUTH_ADMIN_EMAIL=""

# Optional bootstrap admin password used by `npm run auth:seed`.
# Leave empty to generate a password automatically.
AUTH_ADMIN_PASSWORD=""

# Optional comma-separated additional recipients for approval reminder emails.
AUTH_ADMIN_REMINDER_EMAILS=""

# -----------------------------------------------------------------------------
# Entra SSO / Graph mail
# -----------------------------------------------------------------------------

# Enable Microsoft Entra sign-in by setting these values.
ENTRA_CLIENT_ID=""
ENTRA_CLIENT_SECRET=""
ENTRA_TENANT_ID=""

# Optional explicit callback override. Usually derived automatically from
# APP_PUBLIC_URL + BASE_PATH.
# Example:
# ENTRA_REDIRECT_URI="https://lunch.example.com/team-lunch/api/auth/entra/callback"
ENTRA_REDIRECT_URI=""

# Optional advanced override for OpenID discovery. Mainly useful for testing.
ENTRA_OPENID_CONFIGURATION_URL=""

# Optional sender mailbox/user ID for Microsoft Graph email delivery.
GRAPH_MAIL_SENDER=""

# Optional real-recipient smoke-test target for Graph mail tests.
GRAPH_MAIL_TEST_RECIPIENT=""

# -----------------------------------------------------------------------------
# App behavior
# -----------------------------------------------------------------------------

# How many minutes before food selection closes reminder emails should be sent.
FOOD_SELECTION_REMINDER_MINUTES_BEFORE="5"

# -----------------------------------------------------------------------------
# Test / CI overrides
# -----------------------------------------------------------------------------

# Force PostgreSQL server tests instead of falling back to SQLite when the DB is
# unavailable.
FORCE_POSTGRES_TESTS="false"

# Allow running tests against the `public` schema. This is dangerous and should
# normally remain false.
ALLOW_DANGEROUS_TEST_SCHEMA="false"

# Test-only authorization toggle used by some server tests.
AUTHZ_ENFORCE_ADMIN="false"
